<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Jacquet_Valet_App.Onglet2Page"
             Title="Liste des Films">
    
    <ScrollView>
        <StackLayout Padding="20" Spacing="15">
            <Label Text="Liste des Films" FontSize="24" HorizontalOptions="Center" FontAttributes="Bold"/>

            <!-- Affichage de l'erreur de chargement -->
            
            <Frame BackgroundColor="#FFE4E4" BorderColor="#FF0000" CornerRadius="8" HasShadow="True" IsVisible="{Binding IsErrorVisible}" Padding="15" Margin="0,10">
                <StackLayout Spacing="8">
                    <Label Text="Erreur de chargement" FontSize="14" FontAttributes="Bold" TextColor="#CC0000"/>
                    <Label Text="{Binding ErrorMessage}" FontSize="12" TextColor="#660000" LineBreakMode="WordWrap"/>
                </StackLayout>
            </Frame>

            <!-- Affichage du chargement -->
            
            <Label Text="Chargement en cours..." FontSize="12" IsVisible="{Binding LoadMoviesCommand.IsRunning}" HorizontalOptions="Center" TextColor="Gray" Margin="0,10"/>

            <!-- Affichage de la liste des films -->
            <!-- Utilisation d'une CollectionView pour afficher les films -->
            <!-- Binding de la liste des films à la propriété MovieList du ViewModel -->
            
            <CollectionView ItemsSource="{Binding MovieList}" SelectionMode="Single" HeightRequest="700">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <StackLayout Padding="8" Spacing="10" Margin="5">
                            <Label Text="{Binding Title}" FontSize="13" FontAttributes="Bold" HorizontalOptions="Center" TextColor="White"/>
                            <ImageButton Source="{Binding PosterURL}" 
                                         Aspect="AspectFill" 
                                         HeightRequest="300" 
                                         WidthRequest="200"
                                         CornerRadius="10"
                                         BorderColor="Gray"
                                         BorderWidth="1"
                                         Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.GoToDetailCommand}" 
                                         CommandParameter="{Binding .}"
                                         BackgroundColor="White"/>
                        </StackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </StackLayout>
    </ScrollView>
</ContentPage>

<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Jacquet_Valet_App.Models"
             x:Class="Jacquet_Valet_App.Onglet2Page"
             Title="Liste des Films">
    
    <ScrollView>
        <StackLayout Padding="20">
             <Label Text="Liste des Films" FontSize="24" HorizontalOptions="Center"/>

             <!-- Message erreur en cas de problème de chargement -->
             <Label Text="{Binding _errorMessage}" TextColor="Red" IsVisible="{Binding IsErrorVisible}" HorizontalOptions="Center" Margin="0,10"/>

             
             <Label Text="Chargement en cours..." FontSize="12" IsVisible="{Binding IsLoadingVisible}" HorizontalOptions="Center" TextColor="Gray"/>
             
             <!-- CollectionView pour afficher la liste des films -->
            
            <CollectionView ItemsSource="{Binding _movieList}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <StackLayout Padding="10" Spacing="5">
                            <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold"/>
                            <Image Source="{Binding PosterURL}" Aspect="AspectFill" HeightRequest="200" WidthRequest="150"/>
                        </StackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </StackLayout>
    </ScrollView>
</ContentPage>
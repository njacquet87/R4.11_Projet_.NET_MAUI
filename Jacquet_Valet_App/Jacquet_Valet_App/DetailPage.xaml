<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Jacquet_Valet_App.DetailPage">
    <ContentPage.Content>
        <ScrollView>
            <StackLayout Padding="20" Spacing="15">
                <Label Text="{Binding Movie.Title}" FontSize="24" HorizontalOptions="Center" FontAttributes="Bold"/>

                <Image Aspect="AspectFit" HeightRequest="400" HorizontalOptions="Center">
                    <!-- Binding de l'url du film avec la source de l'image -->
                    <Image.Source>
                        <UriImageSource Uri="{Binding Movie.PosterURL}" CachingEnabled="True" CacheValidity="14"/>
                    </Image.Source>
                </Image>
                
                <!-- Affichage des détails du film -->
                <HorizontalStackLayout Padding="20" HorizontalOptions="Center">
                    <Label Text="Id du film : " HorizontalOptions="Center"></Label>
                    <Label Text="{Binding Movie.Id}" FontSize="14" HorizontalOptions="Center"/>
                </HorizontalStackLayout>
                
                <HorizontalStackLayout Padding="20" HorizontalOptions="Center">
                    <Label Text="Id IMBD : "></Label>
                    <Label Text="{Binding Movie.ImdbId}" FontSize="14" HorizontalOptions="Center"/>
                </HorizontalStackLayout>
            </StackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>
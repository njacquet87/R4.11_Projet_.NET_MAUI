<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Jacquet_Valet_App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Jacquet_Valet_App"
    Title="Jacquet_Valet_App"
    Shell.TabBarForegroundColor="Black"
    Shell.TabBarUnselectedColor="Blue"
    Shell.TabBarBackgroundColor="LightGray"
    Shell.TabBarTitleColor="gray">
    
    <TabBar>
        <Tab Title="Home" Icon="home.png">
            <ShellContent ContentTemplate="{DataTemplate local:Onglet1Page}"></ShellContent>
        </Tab>
        
        <Tab Title="Liste" Icon="liste.png">
            <ShellContent ContentTemplate="{DataTemplate local:Onglet2Page}"></ShellContent>
        </Tab>
        
        <Tab Title="Ajout" Icon="plus.png">
            <ShellContent ContentTemplate="{DataTemplate local:Onglet3Page}"></ShellContent>
        </Tab>
        
        <Tab Title="onglet4" Icon="dotnet_bot.png">
            <ShellContent ContentTemplate="{DataTemplate local:Onglet4Page}"></ShellContent>
        </Tab>
    </TabBar>
    
</Shell>

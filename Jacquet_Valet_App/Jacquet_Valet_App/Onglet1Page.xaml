<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Jacquet_Valet_App.ViewModels"
             x:Class="Jacquet_Valet_App.Onglet1Page">

    <!-- Définition du contexte de données pour la page pour le carousel -->
    <ContentPage.BindingContext>
        <viewmodels:BeerViewModel />
    </ContentPage.BindingContext>
    
    <StackLayout Padding="20">
         <Label Text="Bienvenu sur notre App" FontSize="24" HorizontalOptions="Center"/>
         <Label Text="App de bierre" FontSize="12" HorizontalOptions="Center"></Label>
         
         <FlexLayout Padding="20" JustifyContent="Center">
             <!-- images provisoires -->
             <Image Source="dotnet_bot.png" WidthRequest="150" HeightRequest="150" Margin="25"/>
             <Image Source="dotnet_bot.png" WidthRequest="150" HeightRequest="150" Margin="25"/>
         </FlexLayout>
         
         <Button Text="Cliquer pour voir le GIF"
                 VerticalOptions="Center"
                 HorizontalOptions="Center"
                 Clicked="OnButtonClicked"></Button>
         
         <Label Text="Carousel : " FontSize="12"></Label>
         
         <CarouselView ItemsSource="{Binding Beers}">
             <CarouselView.ItemTemplate>
                 <DataTemplate x:DataType="viewmodels:BeerItem">
                     <VerticalStackLayout Padding="20" Spacing="10">
                         <Image Source="{Binding ImagePath}" 
                                HeightRequest="300" 
                                Aspect="AspectFit" />
                     </VerticalStackLayout>
                 </DataTemplate>
             </CarouselView.ItemTemplate>
         </CarouselView>
         
    </StackLayout>

</ContentPage>
